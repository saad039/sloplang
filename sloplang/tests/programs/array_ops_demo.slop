fn next_rand(seed) {
    <- (seed * [1103515245] + [12345]) % [2147483648]
}

fn write_summary(label, arr) {
    n = #arr
    if n > [5] {
        lo = n - [5]
        .>> "results.txt" label
        .>> "results.txt" ": len="
        .>> "results.txt" str(#arr)
        .>> "results.txt" " first5="
        .>> "results.txt" str(arr::0::5)
        .>> "results.txt" " last5="
        .>> "results.txt" str(arr::lo::n)
        .>> "results.txt" "\n"
    } else {
        .>> "results.txt" label
        .>> "results.txt" ": len="
        .>> "results.txt" str(#arr)
        .>> "results.txt" " all="
        .>> "results.txt" str(arr)
        .>> "results.txt" "\n"
    }
    <- arr
}

// Clear output file
.> "results.txt" ""

// Build array of N elements
n = [SIZE_PLACEHOLDER]
arr = []
seed = [42]
i = [0]
for {
    if i == n { break }
    seed = next_rand(seed)
    arr << (seed % [1000])
    i = i + [1]
}
write_summary("built", arr)

// Insert: push 5 elements
j = [0]
for {
    if j == [5] { break }
    seed = next_rand(seed)
    arr << (seed % [1000])
    j = j + [1]
}
write_summary("after_insert", arr)

// Search: contains check
if #arr > [0] {
    target = arr@0
    .>> "results.txt" "search_first: "
    .>> "results.txt" str(arr ?? target)
    .>> "results.txt" "\n"
}
.>> "results.txt" "search_missing: "
.>> "results.txt" str(arr ?? [9999])
.>> "results.txt" "\n"

// Delete: remove first element if non-empty
if #arr > [0] {
    removed = arr ~@ [0]
    .>> "results.txt" "removed: "
    .>> "results.txt" str(removed)
    .>> "results.txt" "\n"
}
write_summary("after_delete", arr)

// Update: set index 0 if non-empty
if #arr > [0] {
    arr@0 = [777]
    .>> "results.txt" "updated_0: [777]\n"
}
write_summary("after_update", arr)
