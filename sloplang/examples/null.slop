// Forward declaration with null
x = [null]
|> str(x)

// Reassign from null
x = [42]
|> str(x)

// Null in arrays
arr = [null, null, null]
|> str(arr)

// Null equality
if [null] == [null] {
    |> "null equals null"
}

// Null inequality
if [null] != [5] {
    |> "null is not 5"
}

// Length counts null elements
|> str(#[null, null])

// Contains finds null
if [1, null, 3] ?? [null] {
    |> "array contains null"
}

// str(null) returns "null"
|> str([null])
